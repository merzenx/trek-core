{
  "$schema": "https://json.schemastore.org/package",
  "name": "trek-core",
  "version": "0.2.0",
  "bin": {
    "trek-core": "./dist/cli/cli.cjs"
  },
  "files": [
    "./dist"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/wasm/trek_ui.js",
    "./dist/wasm/trek_ui_bg.wasm"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./ui": {
      "import": "./dist/ui/index.mjs",
      "types": "./dist/ui/index.d.mts"
    },
    "./ui/theme": {
      "import": "./dist/ui/theme/index.mjs",
      "types": "./dist/ui/theme/index.d.mts"
    },
    "./api": {
      "import": "./dist/api/index.mjs",
      "types": "./dist/api/index.d.mts"
    },
    "./trek.css": {
      "import": "./dist/ui/trek.css",
      "default": "./dist/ui/trek.css"
    },
    "./wasm": {
      "import": "./dist/wasm/trek_ui.js",
      "types": "./dist/wasm/trek_ui.d.ts"
    },
    "./wasm/*": {
      "import": "./dist/wasm/*.js",
      "types": "./dist/wasm/*.d.ts"
    },
    "./wasm/trek_ui_bg.wasm": {
      "import": "./dist/wasm/trek_ui_bg.wasm",
      "default": "./dist/wasm/trek_ui_bg.wasm"
    }
  },
  "scripts": {
    "build": "tsdown",
    "generate:exports": "pnpm dlx tsx scripts/generate-exports.ts",
    "fmt": "oxfmt .",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@inquirer/prompts": "^8.4.1",
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "husky": "^9.1.7",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "oxfmt": "^0.44.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vaul": "^1.1.2",
    "zustand": "^5.0.12"
  },
  "packageManager": "pnpm@10.32.1"
}
